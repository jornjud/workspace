rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isAuthenticated() {
      return request.auth != null;
    }

    function isStaff() {
      return isAuthenticated() && request.auth.token.staff == true;
    }
    
    // --- Customers Collection ---
    match /customers/{uid} {
      allow create: if (isAuthenticated() && request.auth.uid == uid) || isStaff();
      allow read: if (isAuthenticated() && request.auth.uid == uid) || isStaff();
      allow update: if isStaff() || (request.auth.uid == uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name']));
      allow delete: if false;
    }

    // --- Rewards Collection ---
    match /rewards/{rewardId} {
      allow read: if true;
      allow write: if isStaff();
    }
    
    // --- Transactions Collection ---
    match /transactions/{transactionId} {
      allow create: if isStaff();
      allow read: if isStaff() || (isAuthenticated() && resource.data.customerId == request.auth.uid);
      
      // ✨ MODIFIED LINE BELOW ✨
      // Allow staff to update a transaction (to mark it as 'undone')
      allow update: if isStaff();

      // Deleting transactions is not allowed to maintain history
      allow delete: if false;
    }
  }
}